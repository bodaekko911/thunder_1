# Application
APP_ENV=development
APP_NAME=ERP System
DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_PASSWORD=change-me-now
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_EMAIL=admin@example.com

# API
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=1
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
MIGRATION_CHECK_ON_STARTUP=true
MIGRATION_CHECK_STRICT=false
ALLOWED_HOSTS=localhost,127.0.0.1

# Security
COOKIE_SECURE=false
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT=5/minute

# Database and cache
POSTGRES_DB=erp
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp
DATABASE_URL=postgresql+asyncpg://erp:erp@localhost:5432/erp
REDIS_URL=redis://localhost:6379/0
POOL_SIZE=10
POOL_MAX_OVERFLOW=20

# Production overrides
# APP_ENV=production
# DEBUG=false
# WORKERS=2
# COOKIE_SECURE=true
# ALLOWED_HOSTS=erp.example.com,api.erp.example.com
# CORS_ALLOW_ORIGINS=https://erp.example.com
# DATABASE_URL=postgresql+asyncpg://erp:strong-password@postgres:5432/erp
